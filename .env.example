# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/oneoften?schema=public"
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=oneoften

# Redis
REDIS_URL="redis://localhost:6379"

# Stripe (Mock mode by default — must be `false` in production)
STRIPE_MOCK=true
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Email (Mock mode by default — must be `false` in production)
EMAIL_MOCK=true
RESEND_API_KEY=re_placeholder
# Sender shown in customer mails. Must be a verified Resend domain in production.
RESEND_FROM_EMAIL="1of10 <onboarding@resend.dev>"

# Agent Runtime
AGENTS_API_URL=http://localhost:8000
OPENAI_API_KEY=sk-placeholder
# Shared secret used by the web app to call back into agents (key-delivery, etc.)
AGENTS_INTERNAL_SECRET=change-me-32-byte-random-string

# Admin authentication
# Set ADMIN_EMAIL + a bcrypt hash of the password (generate via `npx bcryptjs hash 'yourpassword'`).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2a$10$placeholder_bcrypt_hash
# Server-side HMAC secret for the admin session cookie (32+ random bytes).
SESSION_SECRET=change-me-32-byte-random-string
# Optional fallback API key for header-based admin auth (used by deploy scripts).
ADMIN_API_KEY=dev-admin-key-change-in-production

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analytics (Plausible — leave empty to disable)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# DSD Europe Distributor API
DSD_API_BASE_URL=https://www.dsdeurope.nl/api2s
DSD_API_USERNAME=your_dsd_username
DSD_API_PASSWORD=your_dsd_password
# Fulfilment mode for license key delivery: "quickorder" (default — single call,
# requires customer name+address) or "activateProduct" (legacy, requires a key
# already on the DSD account). See docs/adr/ADR-002-dsd-quickorder.md.
DSD_FULFILMENT_MODE=quickorder

# MiroFish Customer Simulation (optional)
MIROFISH_ENABLED=false
MIROFISH_API_URL=http://localhost:5001
MIROFISH_LLM_API_KEY=
MIROFISH_LLM_MODEL=qwen-plus


# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/oneoften?schema=public"
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=oneoften

# Redis
REDIS_URL="redis://localhost:6379"

# Stripe (Mock mode by default)
STRIPE_MOCK=true
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Email (Mock mode by default)
EMAIL_MOCK=true
RESEND_API_KEY=re_placeholder

# Agent Runtime
AGENTS_API_URL=http://localhost:8000
OPENAI_API_KEY=sk-placeholder

# Admin
ADMIN_API_KEY=dev-admin-key-change-in-production

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analytics (Plausible — leave empty to disable)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# DSD Europe Distributor API
DSD_API_BASE_URL=https://www.dsdeurope.nl/api2s
DSD_API_USERNAME=your_dsd_username
DSD_API_PASSWORD=your_dsd_password

# MiroFish Customer Simulation (optional)
MIROFISH_ENABLED=false
MIROFISH_API_URL=http://localhost:5001
MIROFISH_LLM_API_KEY=
MIROFISH_LLM_MODEL=qwen-plus
